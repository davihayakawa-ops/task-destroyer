# Task Destroyer - Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key (required)
ANTHROPIC_API_KEY=your_api_key_here

# Supabase Auth (recommended for public sales)
# If both are set, Supabase Auth is used instead of TASK_DESTROYER_USERS.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-side only. Never expose this in frontend code.
SUPABASE_SERVICE_ROLE_KEY=

# LLM Model (default: claude-sonnet-4-6)
LLM_MODEL=claude-sonnet-4-6

# App Settings
# Use production for public deployments. Production enables stricter config checks.
APP_ENV=development
DATA_DIR=data

# Optional login users.
# If omitted, the app runs in local development mode without a login screen.
# Use password_hash for production instead of plain password.
# TASK_DESTROYER_USERS=[{"email":"admin@example.com","password_hash":"sha256_hex","role":"admin","workspace":"admin"},{"email":"staff@example.com","password":"change-me","role":"member","workspace":"client-a"}]

# Optional monthly LLM call limit per workspace. Set 0 to disable.
TASK_DESTROYER_MONTHLY_CALL_LIMIT=1000

# Bump this when terms/privacy text changes. Users must accept again.
TASK_DESTROYER_TERMS_VERSION=2026-05-18
