# Task Destroyer - Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key (required)
ANTHROPIC_API_KEY=your_api_key_here

# LLM Model (default: claude-sonnet-4-6)
LLM_MODEL=claude-sonnet-4-6

# App Settings
APP_ENV=development
DATA_DIR=data

# Optional login users.
# If omitted, the app runs in local development mode without a login screen.
# Use password_hash for production instead of plain password.
# TASK_DESTROYER_USERS=[{"email":"admin@example.com","password_hash":"sha256_hex","role":"admin","workspace":"admin"},{"email":"staff@example.com","password":"change-me","role":"member","workspace":"client-a"}]
